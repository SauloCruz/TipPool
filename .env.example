# Copy to .env and adjust. Everything deploy-specific lives here —
# moving to Fly/Railway later means changing these values only.

# Bind 0.0.0.0 so tablets/phones on the venue Wi-Fi can reach the app.
HOST=0.0.0.0
PORT=8377

# Where the SQLite file and backups live (created if missing).
DATA_DIR=./data
# Optional explicit override; defaults to $DATA_DIR/tippool.sqlite3
# DB_PATH=./data/tippool.sqlite3

TIMEZONE=America/Los_Angeles
VENUE_NAME=Tavern Law

# First boot only: creates the initial admin when no users exist.
# Remove (or change the password via a new user) after first sign-in.
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=change-me-please

SESSION_DAYS=30

# --- Square sync (M3) ---
# Personal access token (server-side only; never reaches the browser).
# Leave blank to run manual-entry only.
SQUARE_ACCESS_TOKEN=
# One or more Square location IDs, comma-separated. Multiple locations are
# treated as ONE venue: every daily pull covers all of them and everything
# flows into the same single tip pool.
SQUARE_LOCATION_ID=
# sandbox | production
SQUARE_ENV=sandbox
# Nightly auto-sync of the prior day (skips finalized days), per venue.
NIGHTLY_SYNC=1
NIGHTLY_SYNC_HOUR=5

# --- Per-venue Square credentials (M5) ---
# La Fontana is a separate Square merchant: its own token and location(s).
# Suffix pattern: SQUARE_<VAR>__<VENUE_SLUG in caps, dashes as underscores>.
# The bare SQUARE_* names above always mean Tavern Law.
SQUARE_ACCESS_TOKEN__LA_FONTANA=
SQUARE_LOCATION_ID__LA_FONTANA=
SQUARE_ENV__LA_FONTANA=sandbox
